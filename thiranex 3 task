import numpy as np
import pandas as pd
import re
from sklearn.model_selection import train_test_split
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.ensemble import RandomForestClassifier
from sklearn.pipeline import FeatureUnion, Pipeline
from sklearn.base import BaseEstimator, TransformerMixin
from sklearn.metrics import accuracy_score, classification_report, confusion_matrix

# ==========================================
# 1. GENERATE SYNTHETIC DATASET FOR TESTING
# ==========================================
def generate_sample_data():
    """Generates mock email data balancing Phishing and Safe examples."""
    phishing_emails = [
        "URGENT: Your account access is suspended! Click here http://secure-login-bank.com to verify your identity.",
        "Dear customer, we detected suspicious activity. Reset password now at http://paypal-security-update.net immediately!",
        "You won a $1,000 gift card! Claim your prize now by clicking this link: http://win-free-rewards.xyz",
        "Official notice from IRS: Tax refund is pending. Submit info at http://irs-refund-portal.org",
        "Your package delivery failed. Verify address at http://fedex-tracking-alert.com before tomorrow."
    ]
    
    safe_emails = [
        "Hi Team, please find attached the updated project roadmap for Q3. Let me know if you have any questions.",
        "Your weekly subscription receipt for streaming services is ready. Thank you for your payment.",
        "Hey, are we still meeting for lunch at 12:30 PM today? Let me know.",
        "The scheduled server maintenance is complete. All internal dashboard systems are running smoothly.",
        "Please review the minutes of yesterday's department meeting and provide feedback by Friday."
    ]
    
    # 1 represents "Phishing", 0 represents "Safe"
    data = {
        'text': phishing_emails + safe_emails,
        'label': [1] * len(phishing_emails) + [0] * len(safe_emails)
    }
    return pd.DataFrame(data)

# ==========================================
# 2. CUSTOM STRUCTURAL FEATURE EXTRACTOR
# ==========================================
class StructuralFeatureExtractor(BaseEstimator, TransformerMixin):
    """Extracts numeric metadata characteristics like URL counts and punctuation."""
    def fit(self, X, y=None):
        return self

    def transform(self, X):
        features = []
        for text in X:
            # Check for standard web links matching http or https
            url_count = len(re.findall(r'https?://\S+|www\.\S+', text.lower()))
            # Count panic/urgency indicators (exclamation marks)
            exclamation_count = text.count('!')
            # Track high-risk urgent triggers
            has_urgent_keyword = 1 if any(word in text.lower() for word in ['urgent', 'suspend', 'verify', 'login', 'action']) else 0
            
            features.append([url_count, exclamation_count, has_urgent_keyword])
            
        return np.array(features)

# ==========================================
# 3. MAIN MACHINE LEARNING PIPELINE
# ==========================================
def main():
    print("Initializing Phishing Email Detection Pipeline...\n")
    
    # Load dataset
    df = generate_sample_data()
    X = df['text']
    y = df['label']
    
    # Split data into train and validation subsets
    X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.4, random_state=42, stratify=y)
    
    # Combine structural indicator features with textual TF-IDF vocabulary tokens
    feature_processing = FeatureUnion([
        ('structural_features', StructuralFeatureExtractor()),
        ('tfidf_features', TfidfVectorizer(stop_words='english', max_features=100))
    ])
    
    # Combine feature engineering with a Random Forest Classifier
    pipeline = Pipeline([
        ('features', feature_processing),
        ('classifier', RandomForestClassifier(n_estimators=50, random_state=42))
    ])
    
    # Train the machine learning engine
    pipeline.fit(X_train, y_train)
    print("Model Training Successfully Completed.\n")
    
    # Execute evaluation predictions
    predictions = pipeline.predict(X_test)
    
    # ==========================================
    # 4. METRIC AND CONFUSION MATRIX DISPLAY
    # ==========================================
    accuracy = accuracy_score(y_test, predictions)
    print(f"--- Model Metrics ---")
    print(f"Overall Model Accuracy: {accuracy * 100:.2f}%\n")
    
    print("Detailed Classification Profile:")
    print(classification_report(y_test, predictions, target_names=['Safe', 'Phishing']))
    
    print("Confusion Matrix Output:")
    cm = confusion_matrix(y_test, predictions)
    cm_dataframe = pd.DataFrame(cm, index=['Actual Safe', 'Actual Phishing'], columns=['Predicted Safe', 'Predicted Phishing'])
    print(cm_dataframe)
    print("\n" + "="*50 + "\n")
    
    # ==========================================
    # 5. REAL-TIME SAMPLE PREDICTION INFERENCE
    # ==========================================
    print("--- Live Inference Verification ---")
    live_scenarios = [
        "Urgent security alert! Someone accessed your account from an unknown IP. Log in here to secure your profile: http://fake-auth.com",
        "Hi John, can you review the attached budget spreadsheet before tomorrow's team sync? Thanks."
    ]
    
    live_predictions = pipeline.predict(live_scenarios)
    for email, classification in zip(live_scenarios, live_predictions):
        status = "⚠️ Phishing" if classification == 1 else "✅ Safe"
        print(f"\n[Analyzed Input]: \"{email}\"")
        print(f"[Model Classification]: {status}")

if __name__ == "__main__":
    main()
